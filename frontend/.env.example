# ── AWS API + Cognito (used by src/lib/api.js) ───────────────────
REACT_APP_API_BASE_URL=https://your-api-load-balancer-dns-or-domain
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_COGNITO_DOMAIN=your-cognito-domain
REACT_APP_AWS_REGION=ap-south-1

# ── Legacy Supabase client (src/lib/supabase.js — unused by current
#    code paths, kept only for reference from the pre-AWS-migration setup) ──
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
