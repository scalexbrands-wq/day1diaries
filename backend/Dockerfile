# ── Day1 Diaries API — Docker image ──────────────────────────
# Debian-based (not alpine) — @sparticuz/chromium (used for certificate
# PDF/PNG rendering) needs glibc, which musl-based alpine doesn't have.
FROM node:20-bookworm-slim

# @sparticuz/chromium ships a Lambda-oriented Chromium build that still needs
# these shared libs to launch outside the Lambda runtime (e.g. on ECS/Fargate).
# Without them puppeteer fails with "Failed to launch the browser process!".
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates fonts-liberation fonts-noto-color-emoji fonts-dejavu-core libasound2 libatk-bridge2.0-0 libatk1.0-0 \
    libcairo2 libcups2 libdbus-1-3 libexpat1 libfontconfig1 libgbm1 \
    libglib2.0-0 libgtk-3-0 libnspr4 libnss3 libpango-1.0-0 libpangocairo-1.0-0 \
    libx11-6 libx11-xcb1 libxcb1 libxcomposite1 libxcursor1 libxdamage1 \
    libxext6 libxfixes3 libxi6 libxrandr2 libxrender1 libxss1 libxtst6 \
    wget xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY src ./src
COPY scripts ./scripts

EXPOSE 4000

ENV NODE_ENV=production

CMD ["node", "src/index.js"]
