# ── Database ──────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=day1diaries
DB_USER=day1admin
DB_PASSWORD=your-db-password
DB_SSL=true

# ── Cognito ───────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1

# ── Server ────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=https://your-cloudfront-domain.cloudfront.net
# Public site URL — used to build certificate QR-code links. Defaults
# to the project's CloudFront domain if unset.
# WEBSITE_URL=https://your-cloudfront-domain.cloudfront.net

# ── Brevo (Email Center — transactional email delivery) ──────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=hello@day1diaries.com
BREVO_SENDER_NAME=Day1 Diaries

# ── Auth provider (local dev only) ──────────────────────────────
# Leave unset (or "cognito") for production — uses real AWS Cognito.
# Set to "local" to run the API offline against local Postgres with
# self-signed JWTs instead of Cognito (see routes/auth.local.js and
# backend/local-auth-schema.sql). Not for production.
# AUTH_PROVIDER=local
# LOCAL_JWT_SECRET=some-random-dev-only-secret

# ── WhatsApp welcome message (Meta Cloud API) ───────────────────
# See backend/src/utils/whatsapp.js — leave blank to disable (sends
# are skipped with a console warning, signup/login still work fine).
# WHATSAPP_PHONE_NUMBER_ID is the numeric Phone Number ID from
# Meta Business Manager → WhatsApp Manager → API Setup — NOT the
# actual WhatsApp phone number.
# WHATSAPP_PHONE_NUMBER_ID=+10000000000
# WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# WHATSAPP_TEMPLATE_NAME=your_template_name
# WHATSAPP_TEMPLATE_LANG=en_US
# WHATSAPP_GRAPH_VERSION=v20.0

# ── S3 (certificate/image uploads — optional in local dev) ──────
# Leave unset to fall back to local disk storage under backend/uploads/
# (see backend/src/utils/imageStorage.js). Required for production.
# CERTIFICATES_S3_BUCKET=your-bucket-name
